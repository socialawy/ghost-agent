# ──────────────────────────────────────────────────

# Fast model for interactive chat
llm:
  provider: "openai"
  base_url: "https://api.groq.com/openai/v1"
  api_key: "${GROQ_API_KEY}"
  model: "llama-3.3-70b-versatile"
  max_tokens: 4096
  temperature: 0.3
  min_interval: 3.0
  json_mode_supported: true
  trust_env: false

# Recommended: use a provider cascade for chat so Ghost can keep going
# even if one service is rate-limited or unavailable.
# llm:
#   providers:
#     - provider: "openai"
#       base_url: "http://localhost:11434/v1"
