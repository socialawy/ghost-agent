# Where your state lives
state_dir: ".ghost"

# Your workspace root (for verification gate)
workspace_root: "E:\\co"

# Dream settings
dream:
  min_new_entries: 5          # Minimum new transcript entries before dreaming
  auto_interval_minutes: 30   # autoDream interval in daemon mode
  compact_threshold: 200      # Compact transcript when entries exceed this

# Context management (Phase 5)
context:
  token_budget: 8000          # 0 = unlimited. When set, topics exceeding budget
                              # are collapsed to one-line headers. Recently
                              # referenced topics get priority for full inclusion.

# KAIROS daemon settings
daemon:
  tick_interval_seconds: 60   # How often the daemon wakes up
  watch_paths:                # Paths to watch for changes (optional)
    - "E:\\co\\_meta\\co-registry.csv"

# Optional: dedicated model for dream consolidation
# Falls back to main llm if not specified
# dream_llm:
#   provider: "openai"
#   base_url: "https://api.groq.com/openai/v1"
#   api_key: "${GROQ_API_KEY}"
#   model: "llama-3.3-70b-versatile"
#   max_tokens: 8192
#   temperature: 0.2
#   trust_env: false
