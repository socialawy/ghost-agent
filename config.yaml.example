#       base_url: "https://api.groq.com/openai/v1"
#       api_key: "${GROQ_API_KEY}"
#       model: "llama-3.3-70b-versatile"
#       max_tokens: 4096
#       temperature: 0.3
#       min_interval: 1.0
#       json_mode_supported: true
#       trust_env: false
#     - provider: "openai"
#       base_url: "https://api.deepseek.com/v1"
#       api_key: "${DEEPSEEK_API_KEY}"
#       model: "deepseek-chat"
#       max_tokens: 4096
#       temperature: 0.3
#       min_interval: 2.0
#       json_mode_supported: true
#       trust_env: false

# Smarter model for dream consolidation (Gemini 2.0 Flash — free, fast, smart)
dream_llm:
  provider: "openai"
  base_url: "https://generativelanguage.googleapis.com/v1beta/openai"
  api_key: "${GEMINI_API_KEY}"
  model: "gemini-2.0-flash"
  max_tokens: 8192
  temperature: 0.2
  min_interval: 2
  json_mode_supported: true
  trust_env: false

