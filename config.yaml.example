# ──────────────────────────────────────────────────

# Fast model for interactive chat
llm:
  provider: "openai"
  base_url: "https://api.groq.com/openai/v1"
  api_key: "${GROQ_API_KEY}"
  model: "llama-3.3-70b-versatile"
  max_tokens: 4096
  temperature: 0.3
  min_interval: 3.0

# Smarter model for dream consolidation (Gemini 2.0 Flash — free, fast, smart)
dream_llm:
  provider: "openai"
  base_url: "https://generativelanguage.googleapis.com/v1beta/openai"
  api_key: "${GEMINI_API_KEY}"
  model: "gemini-2.0-flash"
  max_tokens: 8192
  temperature: 0.2
  min_interval: 2
  json_mode_supported: true

# OPTION: OpenRouter Free Models (High Context / Privacy)
# dream_llm:
#   provider: "openai"
#   base_url: "https://openrouter.ai/api/v1"
#   api_key: "${OPENROUTER_API_KEY}"
#   model: "nvidia/nemotron-3-super-120b-a12b:free" # Privacy-safe, 262K context
#   max_tokens: 8192
#   temperature: 0.1
#   min_interval: 3.0
#   json_mode_supported: false # Best for reasoning/nemotron

