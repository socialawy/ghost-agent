# Ghost Agent Environment Variables
# Copy this to .env and fill in your keys.

# LLM Configuration
GHOST_LLM_PROVIDER="openai"
GHOST_LLM_API_KEY="gsk_..."
GHOST_LLM_BASE_URL="https://api.groq.com/openai/v1"
GHOST_LLM_MODEL="llama-3.3-70b-versatile"

# Optional overrides
# GHOST_STATE_DIR=".ghost"
# GHOST_WORKSPACE_ROOT="E:\co"
